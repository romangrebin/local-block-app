rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedEmail() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function memberDoc(communityId, userId) {
      return get(/databases/$(database)/documents/communities/$(communityId)/members/$(userId));
    }

    function communityDoc(communityId) {
      return get(/databases/$(database)/documents/communities/$(communityId));
    }

    function memberExists(communityId, userId) {
      return exists(/databases/$(database)/documents/communities/$(communityId)/members/$(userId));
    }

    function isActiveMember(communityId, userId) {
      return isSignedIn()
        && memberExists(communityId, userId)
        && memberDoc(communityId, userId).data.status == "active";
    }

    function isAdminFor(communityId) {
      return isActiveMember(communityId, request.auth.uid)
        && memberDoc(communityId, request.auth.uid).data.role == "admin";
    }

    function userMemberCommunity(userId) {
      return exists(/databases/$(database)/documents/users/$(userId))
        ? get(/databases/$(database)/documents/users/$(userId)).data.memberCommunityCode
        : null;
    }

    function userPendingCommunity(userId) {
      return exists(/databases/$(database)/documents/users/$(userId))
        ? get(/databases/$(database)/documents/users/$(userId)).data.pendingCommunityCode
        : null;
    }

    function userCommunityCode(userId) {
      return userMemberCommunity(userId) != null
        ? userMemberCommunity(userId)
        : userPendingCommunity(userId);
    }

    function adminUpdatesMemberCode() {
      return request.resource.data.diff(resource.data).changedKeys()
        .hasOnly(["memberCommunityCode", "pendingCommunityCode", "updatedAt"]);
    }

    function selfSetsPendingCommunity(userId) {
      return request.auth.uid == userId
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(["pendingCommunityCode", "updatedAt"])
        && request.resource.data.memberCommunityCode == resource.data.memberCommunityCode
        && request.resource.data.pendingCommunityCode is string;
    }

    function selfClearsCommunityMembership(userId) {
      return request.auth.uid == userId
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(["memberCommunityCode", "pendingCommunityCode", "updatedAt"])
        && resource.data.memberCommunityCode is string
        && request.resource.data.memberCommunityCode == null
        && request.resource.data.pendingCommunityCode == null;
    }

    function hasValidCommunityKeys(data) {
      return data.keys().hasOnly([
        "code",
        "name",
        "content",
        "createdBy",
        "createdAt",
        "updatedAt"
      ]);
    }

    function hasValidCommunityPayload(data, communityId) {
      return hasValidCommunityKeys(data)
        && data.code is string
        && data.code == communityId
        && data.code.size() > 0
        && data.code.size() <= 64
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 120
        && data.content is string
        && data.content.size() <= 10000
        && data.createdBy is string
        && data.createdBy.size() > 0
        && data.createdBy.size() <= 128;
    }

    function hasValidPrivateMemberContentPayload(data) {
      return data.keys().hasOnly(["content", "createdAt", "updatedAt"])
        && data.content is string
        && data.content.size() <= 10000;
    }

    match /communities/{communityId} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn()
        && isVerifiedEmail()
        && request.resource.data.code == communityId
        && request.resource.data.createdBy == request.auth.uid
        && userCommunityCode(request.auth.uid) == null
        && hasValidCommunityPayload(request.resource.data, communityId)
        && !request.resource.data.keys().hasAny(["memberContent"]);
      allow update: if isAdminFor(communityId)
        && isVerifiedEmail()
        && request.resource.data.code == resource.data.code
        && request.resource.data.createdBy == resource.data.createdBy
        && hasValidCommunityPayload(request.resource.data, communityId)
        && !request.resource.data.diff(resource.data).changedKeys().hasAny(["memberContent"]);
      allow delete: if isAdminFor(communityId)
        && isVerifiedEmail();

      match /private/{docId} {
        allow get: if docId == "memberContent"
          && isActiveMember(communityId, request.auth.uid);
        allow list: if false;
        allow create, update: if docId == "memberContent"
          && isAdminFor(communityId)
          && isVerifiedEmail()
          && hasValidPrivateMemberContentPayload(request.resource.data);
        allow delete: if docId == "memberContent"
          && isAdminFor(communityId)
          && isVerifiedEmail();
      }

      match /members/{userId} {
        allow get: if isSignedIn() && (
          request.auth.uid == userId
          || isAdminFor(communityId)
          || (
            isActiveMember(communityId, request.auth.uid)
            && resource.data.role == "admin"
            && resource.data.status == "active"
          )
        );
        allow list: if isAdminFor(communityId);
        allow create: if isSignedIn()
          && isVerifiedEmail()
          && request.resource.data.userId == userId
          && request.resource.data.communityCode == communityId
          && exists(/databases/$(database)/documents/communities/$(communityId))
          && (
            request.auth.uid == userId
            || (
              isAdminFor(communityId)
              && request.resource.data.status == "active"
            )
          )
          && (
            request.resource.data.role == "member"
            || request.resource.data.role == "admin"
          )
          && (
            request.resource.data.role != "admin"
            || communityDoc(communityId).data.createdBy == userId
          )
          && (
            request.resource.data.status == "pending"
            || request.resource.data.status == "active"
          );
        allow update: if isAdminFor(communityId)
          && isVerifiedEmail()
          && request.resource.data.userId == userId
          && request.resource.data.communityCode == communityId
          && request.resource.data.email == resource.data.email;
        allow delete: if isSignedIn()
          && isVerifiedEmail()
          && (
          request.auth.uid == userId
          || isAdminFor(communityId)
        );
      }
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn()
        && request.auth.uid == userId;
      allow update: if isSignedIn()
        && isVerifiedEmail()
        && (
          selfSetsPendingCommunity(userId)
          || selfClearsCommunityMembership(userId)
          || (
            adminUpdatesMemberCode()
            && (
              (
                request.resource.data.memberCommunityCode is string
                && isAdminFor(request.resource.data.memberCommunityCode)
              )
              || (
                request.resource.data.memberCommunityCode == null
                && resource.data.memberCommunityCode is string
                && isAdminFor(resource.data.memberCommunityCode)
              )
              || (
                request.resource.data.pendingCommunityCode is string
                && isAdminFor(request.resource.data.pendingCommunityCode)
              )
              || (
                request.resource.data.pendingCommunityCode == null
                && resource.data.pendingCommunityCode is string
                && isAdminFor(resource.data.pendingCommunityCode)
              )
            )
          )
        );
    }
  }
}
