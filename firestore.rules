rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function adminCommunityCode() {
      return exists(/databases/$(database)/documents/communityAdmins/$(request.auth.uid))
        ? get(/databases/$(database)/documents/communityAdmins/$(request.auth.uid)).data.communityCode
        : null;
    }

    function isAdminFor(communityId) {
      return isSignedIn() && adminCommunityCode() == communityId;
    }

    match /communities/{communityId} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn()
        && request.resource.data.code == communityId
        && !exists(/databases/$(database)/documents/communityAdmins/$(request.auth.uid));
      allow update: if isAdminFor(communityId)
        && request.resource.data.code == resource.data.code;
      allow delete: if isAdminFor(communityId);
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.email == request.auth.token.email;
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.email == resource.data.email;
    }

    match /communityAdmins/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if isSignedIn() && adminCommunityCode() == resource.data.communityCode;
      allow create: if isSignedIn()
        && request.resource.data.userId == userId
        && request.resource.data.communityCode is string
        && request.resource.data.email is string
        && !exists(/databases/$(database)/documents/communityAdmins/$(userId))
        && exists(/databases/$(database)/documents/communities/$(request.resource.data.communityCode))
        && (
          request.auth.uid == userId
          || adminCommunityCode() == request.resource.data.communityCode
        );
      allow update: if isSignedIn()
        && request.resource.data.userId == userId
        && request.resource.data.communityCode == resource.data.communityCode
        && request.resource.data.email == resource.data.email
        && (
          request.auth.uid == userId
          || adminCommunityCode() == resource.data.communityCode
        );
      allow delete: if isSignedIn()
        && (
          request.auth.uid == userId
          || adminCommunityCode() == resource.data.communityCode
        );
    }
  }
}
